# Copie para .env.whatsapp e preencha os valores.
# Nunca commite .env.whatsapp com secrets.

RESTAURANT_SLUG=seu-restaurante
API_BASE_URL=https://cardapionamesa.com

# Opcional — habilita respostas com IA para perguntas livres
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Guardrails anti-loop e anti-spam
SESSION_TTL_MS=1800000
MAX_CONVERSATION_HISTORY=6
MAX_MESSAGES_PER_MINUTE=8
DUPLICATE_MESSAGE_WINDOW_MS=15000
MAX_CONSECUTIVE_BOT_REPLIES=5

# Pasta de sessão Baileys (persistida no volume Docker)
BAILEYS_AUTH_DIR=./auth

# Cache da config do restaurante (ms)
CONFIG_REFRESH_MS=60000

# Tempo de handoff humano após pedir atendente (minutos)
HANDOFF_MINUTES=30

# HTTP interno (status + QR code para o admin)
HTTP_PORT=3001

# Chave compartilhada com a API (WHATSAPP_BOT_API_KEY no .env da api)
WHATSAPP_BOT_API_KEY=troque-por-uma-chave-segura

LOG_LEVEL=info
